# JWT secret — change this to a long random string in production!
JWT_SECRET=change-this-to-a-random-secret-in-production

# OpenRouter API key — can also be configured via Admin UI after first launch
OPENROUTER_API_KEY=

# Optional: email that gets admin role on first registration
ADMIN_EMAIL=

# Port the app will be accessible on (default: 3000)
# PORT=3000
